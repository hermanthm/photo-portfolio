# App runtime — Transaction pooler (Vercel/serverless)
DATABASE_URL="postgresql://postgres.PROJECT_REF:password@aws-1-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require&connect_timeout=10"

# Migrations only — Session pooler (required for prisma migrate deploy)
MIGRATE_DATABASE_URL="postgresql://postgres.PROJECT_REF:password@aws-1-REGION.pooler.supabase.com:5432/postgres?sslmode=require&connect_timeout=10"

# Do NOT use direct connection (db.PROJECT_REF.supabase.co:5432) — often unreachable.

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-secret"
AUTH_URL="http://localhost:3000"

# Seed credentials (used by prisma/seed.ts — run once after first deploy)
ADMIN_EMAIL="admin@portfolio.local"
ADMIN_PASSWORD="changeme123"

# Cloudinary (required for photo and OG image uploads)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""