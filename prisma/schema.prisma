generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CollectionType {
  photo
  video
  mixed
}

enum DefaultView {
  mosaic
  slideshow
}

enum VideoProvider {
  youtube
  vimeo
  other
}

enum WorkCategoryScope {
  photography
  video
  both
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model WorkCategory {
  id          String            @id @default(cuid())
  name        String
  slug        String            @unique
  scope       WorkCategoryScope @default(both)
  sortOrder   Int               @default(0)
  collections Collection[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([sortOrder])
}

model Collection {
  id           String         @id @default(cuid())
  slug         String         @unique
  title        String
  description  String?
  type         CollectionType @default(mixed)
  defaultView  DefaultView    @default(mosaic)
  published    Boolean        @default(false)
  featured     Boolean        @default(false)
  sortOrder    Int            @default(0)
  categoryId   String?
  category     WorkCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  coverPhotoId String?        @unique
  coverPhoto   Photo?         @relation("CollectionCoverPhoto", fields: [coverPhotoId], references: [id], onDelete: SetNull)
  coverVideoId String?        @unique
  coverVideo   Video?         @relation("CollectionCoverVideo", fields: [coverVideoId], references: [id], onDelete: SetNull)
  photos       Photo[]
  videos       Video[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([categoryId])
}

model Photo {
  id                 String      @id @default(cuid())
  collectionId       String
  collection         Collection  @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  coverForCollection Collection? @relation("CollectionCoverPhoto")
  cloudinaryId String?
  url          String
  alt          String?
  width        Int        @default(0)
  height       Int        @default(0)
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([collectionId])
}

model Video {
  id                 String        @id @default(cuid())
  collectionId       String
  collection         Collection    @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  coverForCollection Collection?   @relation("CollectionCoverVideo")
  title        String
  description  String?
  embedUrl     String
  provider     VideoProvider @default(other)
  thumbnailUrl String?
  sortOrder    Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([collectionId])
}

model SiteSettings {
  id            String   @id @default("default")
  siteTitle     String   @default("Photo Portfolio")
  bio           String?
  footerTagline String?
  contactBlurb  String?
  contactEmail  String?
  instagram     String?
  vimeo         String?
  youtube       String?
  ogImageUrl    String?
  updatedAt     DateTime @updatedAt
}